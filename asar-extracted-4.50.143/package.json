    "node": ">= 24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tinyspeck/slack-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/tinyspeck/slack-desktop/issues"
  },
  "linuxPackageInfo": {
    "categories": "GNOME;GTK;Network;InstantMessaging",
    "genericName": "Slack Client for Linux",
    "section": "misc"
  },
  "supportedOS": {
    "darwin": ">= 10.10"
  },
  "lint-staged": {
    "src/common/{interfaces,constants,utils}/**/*.ts": [
      "ts-node --transpile-only ./build/cli/publish-types/check-and-update-metadata.ts",
      "git add src/common/metadata/*.metadata.json",
      "prettier --write --experimental-cli",
      "eslint --fix"
    ],
    "{build/cli/publish-types/**/*.ts,src/common/publish-types.config.json}": [
      "yarn run publish-desktop-types",
      "git add src/common/metadata/*.metadata.json"
    ],
    "*.{ts,tsx}": [
      "prettier --write --experimental-cli",
      "eslint --fix"
    ],
    "*.{js,jsx}": [
      "prettier --write --experimental-cli"
    ]
  },
  "private": true,
  "workspaces": [
    "spec/e2e",
    "spec/old-joe",
    "tools/triage-agent"
  ],
  "scripts": {
    "triage": "yarn workspace slack-desktop-triage-agent run triage-agent",
    "analyze-deps": "ts-node --transpile-only ./script/analyze-deps.ts",
    "try-electron": "ts-node --transpile-only ./build/try-electron.ts",
    "print-version": "ts-node --transpile-only ./build/version/index.ts",
    "postinstall": "ts-node --transpile-only ./build/postinstall.ts && ts-node --transpile-only ./build/bootstrap-cli.ts",
    "prepare": "husky install",
    "package": "cross-env NODE_ENV=production ts-node --transpile-only ./build/package-cli.ts",
    "lint": "eslint --ext .ts,.tsx . --cache --cache-strategy content",
    "lint:locales": "ts-node --transpile-only ./build/mas-supported-locale.ts",
    "format-all:check": "prettier --check --experimental-cli build ci script spec src webpack",
    "format-all": "prettier --write --experimental-cli build ci script spec src webpack",
    "start": "yarn build:dev && yarn start:app --",
    "start:app": "cross-env DEBUG='logger\\:*,electron-spellchecker\\:*' NODE_OPTIONS=--trace-deprecation electron . -r . --inspect",
    "start:appx": "cross-env DEBUG='logger\\:*,electron-spellchecker\\:*' NODE_OPTIONS=--trace-deprecation electronmsix . -r . --inspect",
    "test": "cross-env NODE_OPTIONS=--disable-warning=DEP0040 jest",
    "test:webpack": "jest --config ./webpack/spec/jest.json",
    "test:dependencies": "dependency-cruise --validate .dependency-cruiser.js ./src",
    "compile": "tsgo -b ./src/common/tsconfig.json ./src/boot/tsconfig.json ./src/preload/tsconfig.json ./src/browser/tsconfig.json ./src/renderer/tsconfig.json ./webpack/tsconfig.json ./build/tsconfig.json ./spec/jest/tsconfig.json && tsc --noEmit --project ./spec/old-joe/tsconfig.json",
    "clean": "ts-node --transpile-only ./script/clean.ts",
    "build": "tsgo -b ./webpack/tsconfig.json && node ./.webpack/runner.js",
    "build:dev": "yarn build",
    "build:prod": "yarn build --prod",
    "licenses": "ts-node --transpile-only ./build/generate-license.ts",
    "dependencies": "depcruise -X \"node_modules\" --output-type dot src | dot -T svg > dependencygraph.svg",
    "changelog": "ts-node --transpile-only ./script/changelog.ts",
    "extract-strings": "ts-node --transpile-only ./script/extract-strings.ts",
    "codesign": "ts-node --transpile-only ./build/cli/codesign.ts",
    "publish-desktop-types": "ts-node --transpile-only ./build/cli/publish-types/index.ts",
    "update-server": "ts-node --transpile-only ./spec/e2e/utils/fake-update-server.ts",
    "https-auth-proxy": "ts-node --transpile-only ./spec/e2e/utils/https-auth-proxy.ts",
    "release-artifact-notification": "ts-node --transpile-only ./ci/common/release-artifact-notification.ts",
    "electron-versions": "electron-versions -f \">3.999\" -l 1000 -p alpha,beta,eta --write-markdown --write-json",
    "packagecloud": "ts-node --transpile-only ./build/cli/packageCloud/index.ts",
    "analyze-rxjs": "ts-node --transpile-only ./script/analyze-rxjs-refactor.ts"
  },
