{
  "name": "@tinyspeck/slack-desktop-utils",
  "version": "1.18.7",
  "description": "Native extensions for the Slack desktop client",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "install": "node-pre-gyp install --fallback-to-build --runtime=electron --target=27.0.2 --dist-url=https://electronjs.org/headers",
    "postinstall": "node-pre-gyp configure --runtime=electron --target=27.0.2 --dist-url=https://electronjs.org/headers",
    "build": "node-pre-gyp build --build-from-source --runtime=electron --target=27.0.2 --dist-url=https://electronjs.org/headers",
    "build:ci": "node-pre-gyp clean rebuild --build-from-source --runtime=electron --target=27.0.2 --dist-url=https://electronjs.org/headers",
    "build:debug": "node-pre-gyp build --build-from-source --debug --runtime=electron --target=27.0.2 --dist-url=https://electronjs.org/headers",
    "test": "node --test",
    "test:msix": "npx --yes msix-node test.js",
    "package": "node-pre-gyp package",
    "upload-bins": "node ./ci/upload.js",
    "clean": "node-pre-gyp clean",
    "start:demo": "electron demo/app.js"
  },
  "author": "Salesforce, Inc.",
  "license": "UNLICENSED",
  "dependencies": {
    "@tinyspeck/node-pre-gyp": "^1.0.17",
    "bindings": "^1.5.0",
    "node-addon-api": "^6.1.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.378.0",
    "electron": "^32.1.2",
    "read-binary-file-arch": "^1.0.6"
  },
  "gypfile": true,
  "publishConfig": {
    "registry": "https://slack.jfrog.io/slack/api/npm/npm-registry/"
  },
  "prettier": {
    "singleQuote": true
  },
  "binary": {
    "module_name": "slackdesktoputils",
    "module_path": "./lib/binding/napi-v{napi_build_version}",
    "package_name": "{module_name}-v{version}-napi-v{napi_build_version}-{platform}-{arch}.tar.gz",
    "staging_host": "https://slack-desktop-native-prebuilds-dev.s3.amazonaws.com",
    "production_host": "https://slack-desktop-native-prebuilds.s3.amazonaws.com",
    "napi_versions": [
      8
    ]
  }
}
